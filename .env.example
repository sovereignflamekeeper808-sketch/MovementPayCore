# Deployer private key (NEVER commit this file with real keys)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# RPC Endpoints (get from Alchemy, Infura, or QuickNode)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
GOERLI_RPC_URL=https://eth-goerli.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org/
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Block Explorer API Keys (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
SNOWTRACE_API_KEY=your_snowtrace_api_key

# Gas Reporter
CMC_API_KEY=your_coinmarketcap_api_key
